<Page x:Class="TileMind.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:TileMind.UI.Converters"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d"
      d:DesignHeight="800" d:DesignWidth="600"
      Title="SettingsPage"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="42,24,42,48">

                <!-- 个性化 -->
                <TextBlock FontSize="20" FontWeight="Medium" Text="个性化" />
                <TextBlock Margin="0,12,0,0" Text="主题" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <StackPanel Margin="0,6,0,0">
                    <RadioButton Content="Light" GroupName="themeSelect"
                                 Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}" CommandParameter="theme_light"
                                 IsChecked="{Binding ViewModel.CurrentApplicationTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Light, Mode=OneWay}" />
                    <RadioButton Content="Dark" GroupName="themeSelect"
                                 Command="{Binding ViewModel.ChangeThemeCommand, Mode=OneWay}" CommandParameter="theme_dark"
                                 IsChecked="{Binding ViewModel.CurrentApplicationTheme, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Dark, Mode=OneWay}" />
                </StackPanel>

                <!-- 覆盖层显示 -->
                <TextBlock Margin="0,28,0,0" FontSize="20" FontWeight="Medium" Text="覆盖层显示" />
                <TextBlock Margin="0,6,0,0" Text="控制叠加层上各功能的显隐" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <StackPanel Margin="0,6,0,0">
                    <CheckBox Content="识别框显示" IsChecked="{Binding ViewModel.Overlay.ShowDetectionBoxes}" />
                    <CheckBox Content="识别区域显示" IsChecked="{Binding ViewModel.Overlay.ShowScreenRegions}" />
                    <CheckBox Content="耗时统计显示" IsChecked="{Binding ViewModel.Overlay.ShowTimingStats}" />
                </StackPanel>

                <!-- 屏幕捕获 -->
                <TextBlock Margin="0,28,0,0" FontSize="20" FontWeight="Medium" Text="屏幕捕获" />
                <StackPanel Margin="0,6,0,0">
                    <TextBlock Margin="0,4,0,0" Text="游戏进程名（不含 .exe）" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.ScreenCapture.GameProcessName}" Margin="0,2,0,4" />
                </StackPanel>

                <!-- 流水线 -->
                <TextBlock Margin="0,28,0,0" FontSize="20" FontWeight="Medium" Text="流水线" />
                <StackPanel Margin="0,6,0,0">
                    <CheckBox Content="启用状态追踪" IsChecked="{Binding ViewModel.Pipeline.EnableStateTracking}" />
                </StackPanel>

                <!-- 识别参数 -->
                <TextBlock Margin="0,28,0,0" FontSize="20" FontWeight="Medium" Text="识别参数" />
                <StackPanel Margin="0,6,0,0">
                    <TextBlock Margin="0,4,0,0" Text="模型路径" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Yolo.ModelPath}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="置信度阈值" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Yolo.ConfidenceThreshold}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="IoU 阈值" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Yolo.IouThreshold}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="GPU 设备 ID (-1=CPU)" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Yolo.GpuDeviceId}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="模型输入尺寸" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Yolo.InputSize}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="检测器池大小 (最小/最大)" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal">
                        <TextBox Text="{Binding ViewModel.Yolo.MinDetectorPoolSize}" Width="60" Margin="0,2,4,4" />
                        <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox Text="{Binding ViewModel.Yolo.MaxDetectorPoolSize}" Width="60" Margin="0,2,0,4" />
                    </StackPanel>
                </StackPanel>

                <!-- 融合参数 -->
                <TextBlock Margin="0,28,0,0" FontSize="20" FontWeight="Medium" Text="融合参数" />
                <StackPanel Margin="0,6,0,0">
                    <CheckBox Content="启用多帧融合" IsChecked="{Binding ViewModel.Fusion.EnableFusion}" />
                    <TextBlock Margin="0,4,0,0" Text="融合帧数" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Fusion.MaxFusionFrameCount}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="场景变化阈值" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Fusion.MovementThreshold}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="融合置信度阈值" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Fusion.FusionConfidenceThreshold}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="融合 IoU 阈值" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Fusion.FusionIouThreshold}" Margin="0,2,0,4" />
                </StackPanel>

                <!-- 状态追踪参数 -->
                <TextBlock Margin="0,28,0,0" FontSize="20" FontWeight="Medium" Text="状态追踪参数" />
                <StackPanel Margin="0,6,0,0">
                    <TextBlock Margin="0,4,0,0" Text="帧间匹配 IoU 阈值" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Tracker.MatchIouThreshold}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="连续 Miss 容限" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Tracker.MaxConsecutiveMisses}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="手牌/副露 Gap 倍数" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Tracker.HandMeldGapMultiplier}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="行聚类容差 (px)" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Tracker.RowTolerance}" Margin="0,2,0,4" />
                    <TextBlock Margin="0,4,0,0" Text="副露邻近阈值 (px)" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <TextBox Text="{Binding ViewModel.Tracker.MeldProximityThreshold}" Margin="0,2,0,4" />
                </StackPanel>

                <!-- 保存 -->
                <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                    <ui:Button Appearance="Primary"
                               Command="{Binding ViewModel.SaveSettingsCommand}"
                               Content="Save"
                               Icon="{ui:SymbolIcon Save24}" />
                    <TextBlock Text="{Binding ViewModel.StatusMessage}"
                               FontSize="13" Margin="12,0,0,0" VerticalAlignment="Center"
                               Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部开源许可 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,16">
            <TextBlock Text="MIT License"
                       FontSize="11" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock FontSize="11"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/zzijin/TileMind"
                           RequestNavigate="Hyperlink_RequestNavigate"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextDecorations="Underline">
                    github.com/zzijin/TileMind
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Page>
