<Window x:Class="TileMind.UI.Views.OverlayToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TileMind Toolbar"
        Width="312" Height="54"
        Left="16"
        WindowStartupLocation="Manual"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Border CornerRadius="6" Background="#AA1a1a2e" Padding="8">
        <StackPanel Orientation="Horizontal">
            <Button Content="开始识别" Height="28" Margin="0,0,6,0"
                    Command="{Binding StartPipelineCommand}"
                    Foreground="White" Background="#204080" BorderBrush="#4488cc"
                    FontSize="12" />
            <Button Content="停止" Height="28" Margin="0,0,6,0"
                    Command="{Binding StopPipelineCommand}"
                    Foreground="White" Background="#804040" BorderBrush="#cc6666"
                    FontSize="12" />
            <Button Content="重定位" Height="28" Margin="0,0,6,0"
                    Command="{Binding RelocateCoordinatesCommand}"
                    Foreground="White" Background="#606020" BorderBrush="#888844"
                    FontSize="12" />
            <Button Content="关闭" Height="28"
                    Click="CloseButton_Click"
                    Foreground="White" Background="#404040" BorderBrush="#666"
                    FontSize="12" />
        </StackPanel>
    </Border>
</Window>
